APP_NAME=Kuro
APP_FULL_NAME=AI Kurogane Reijin
APP_VERSION=0.4.0

# ollama | openai
LLM_PROVIDER=ollama
LLM_MODEL=gemma3
LLM_TEMPERATURE=0.7

OLLAMA_MODEL=gemma3
OLLAMA_HOST=http://localhost:11434
OLLAMA_TEMPERATURE=0.7

# Works with OpenAI and OpenAI-compatible servers such as LM Studio/vLLM.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

MEMORY_ENABLED=true
# Number of non-system messages sent to the model. Full history remains in SQLite.
MAX_HISTORY=20

WORKSPACE_PATH=
DATA_DIR=data
DATABASE_PATH=data/kuro.db
DOCUMENTS_DIR=data/documents
MAX_DOCUMENT_SIZE_MB=20
HISTORY_DIR=data/history
MEMORY_DIR=data/memory
LOGS_DIR=data/logs
LOG_FILE=data/logs/kuro.log
LOG_LEVEL=INFO

CHUNK_SIZE=1000
CHUNK_OVERLAP=150

EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BATCH_SIZE=16

RAG_TOP_K=5
RAG_MIN_SIMILARITY=0.35
RAG_MAX_CONTEXT_CHARS=6000